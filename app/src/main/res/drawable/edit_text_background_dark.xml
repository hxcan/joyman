<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- 背景颜色：深灰色 -->
    <solid android:color="#2C2C2C" />
    
    <!-- 边框：中灰色 -->
    <stroke
        android:width="1dp"
        android:color="#424242" />
    
    <!-- 圆角 -->
    <corners android:radius="4dp" />
    
    <!-- 内边距 -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />
</shape>