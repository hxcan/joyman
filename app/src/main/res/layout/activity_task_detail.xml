<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.JoyMan.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.JoyMan.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 任务标题区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- 任务标题 -->
                <TextView
                    android:id="@+id/text_detail_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:text="任务标题" />

                <!-- 复制按钮 -->
                <ImageButton
                    android:id="@+id/btn_copy_title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_save"
                    android:contentDescription="复制标题"
                    android:tooltipText="复制标题到剪贴板" />

            </LinearLayout>

            <!-- 任务描述 -->
            <TextView
                android:id="@+id/text_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#757575"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                android:text="任务描述" />

            <!-- 信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/text_detail_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:layout_marginBottom="12dp"
                        android:text="状态：待办" />

                    <TextView
                        android:id="@+id/text_detail_priority"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:layout_marginBottom="12dp"
                        android:text="优先级：普通" />

                    <TextView
                        android:id="@+id/text_detail_project"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:layout_marginBottom="12dp"
                        android:text="所属项目：无" />

                    <TextView
                        android:id="@+id/text_detail_created_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#9E9E9E"
                        android:text="创建时间：2026-04-01 10:00" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 移动项目 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="移动到项目"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_detail_project"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp" />

            <!-- 保存项目更改按钮 -->
            <Button
                android:id="@+id/btn_save_project"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存项目更改"
                android:backgroundTint="#4CAF50"
                android:layout_marginBottom="12dp" />

            <!-- 操作按钮 -->
            <Button
                android:id="@+id/btn_toggle_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="切换完成状态"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_move_project"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择项目"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="删除任务"
                android:backgroundTint="#F44336" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>