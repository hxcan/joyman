<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.JoyMan.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.JoyMan.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 任务标题区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/text_detail_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:text="任务标题" />

                <ImageButton
                    android:id="@+id/btn_copy_title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_copy"
                    android:contentDescription="复制标题到剪贴板" />

            </LinearLayout>

            <!-- 父任务信息卡片（仅当有父任务时显示） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_parent_task"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E3F2FD"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_revert"
                        android:contentDescription="父任务"
                        android:layout_marginEnd="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="父任务"
                            android:textSize="12sp"
                            android:textColor="#1976D2" />

                        <TextView
                            android:id="@+id/text_parent_task_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#0D47A1"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="父任务标题" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_more"
                        android:contentDescription="查看详情"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 任务描述 -->
            <TextView
                android:id="@+id/text_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                android:text="任务描述" />

            <!-- 信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 任务 ID -->
                    <TextView
                        android:id="@+id/text_detail_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorTertiary"
                        android:layout_marginBottom="8dp"
                        android:text="ID: 0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="状态："
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <TextView
                            android:id="@+id/text_detail_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2196F3"
                            android:text="新建" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_detail_priority"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="12dp"
                        android:text="优先级：普通" />

                    <TextView
                        android:id="@+id/text_detail_project"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="12dp"
                        android:text="所属项目：无" />

                    <TextView
                        android:id="@+id/text_detail_created_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorTertiary"
                        android:text="创建时间：2026-04-01 10:00:00" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 更改状态 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="更改状态"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_status"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp" />

            <!-- 移动项目 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="移动到项目"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_detail_project"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp" />

            <!-- 统一保存按钮 -->
            <Button
                android:id="@+id/btn_save_changes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存更改"
                android:backgroundTint="#2196F3"
                android:enabled="false"
                android:alpha="0.5"
                android:layout_marginBottom="12dp" />

            <!-- 操作按钮 -->
            <Button
                android:id="@+id/btn_create_subtask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="创建子任务"
                android:backgroundTint="#4CAF50"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_move_project"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择项目"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="删除任务"
                android:backgroundTint="#F44336" />

            <!-- 子任务列表区域 -->
            <TextView
                android:id="@+id/text_subtasks_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="子任务"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_subtasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_no_subtasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无子任务"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorTertiary"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>