<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.JoyMan" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
    </style>

    <!-- 无 ActionBar 主题 -->
    <style name="Theme.JoyMan.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- AppBar 覆盖层 -->
    <style name="Theme.JoyMan.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />

    <!-- Popup 覆盖层 -->
    <style name="Theme.JoyMan.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <!-- 按钮样式 -->
    <style name="Theme.JoyMan.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- 卡片样式 -->
    <style name="Theme.JoyMan.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>